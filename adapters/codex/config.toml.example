# Forseti — Codex adapter configuration.
#
# Merge these entries into your Codex config at ~/.codex/config.toml. They (1)
# wire the notify hook as a partial gate, and (2) register the Forseti Core as an
# MCP server so the `verify` tool is reachable. Enforcement of the loop itself is
# the prompt+tools fallback in ./AGENTS.md.
#
# ORDER MATTERS: `notify` is a top-level key, so it must appear BEFORE any
# `[table]` header — TOML assigns every key after a header to that table, which
# would silently turn `notify` into `mcp_servers.forseti.notify` (and Codex,
# reading only a top-level `notify`, would never run it).

# (1) Partial gate: run the reference notify script at the end of each agent
# turn. Codex passes the notify program a single JSON argument. This CANNOT block
# a turn — it only records a reminder when a turn ends (see ./notify.py). Use an
# absolute path to the script.
notify = ["python3", "/absolute/path/to/adapters/codex/notify.py"]

# (2) Forseti Core over MCP (stdio). `forseti mcp` starts the server (#49); it
# needs the `mcp` extra installed:  pip install 'forseti[mcp]'
# Equivalent CLI:  codex mcp add forseti -- forseti mcp
[mcp_servers.forseti]
command = "forseti"
args = ["mcp"]
# startup_timeout_sec = 10           # bump if esbmc/import warm-up is slow
# env = { ESBMC_BIN = "esbmc" }      # override the esbmc binary if not on PATH
